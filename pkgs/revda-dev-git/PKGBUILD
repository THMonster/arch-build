# Maintainer: Megumi_fox <i@megumifox.com>

pkgname=revda-dev-git
pkgver=5.7.0.r9.g02fdfef
pkgrel=3
pkgdesc='Cute and useful Live Stream Player with danmaku support.'
arch=('x86_64')
url="https://github.com/THMonster/Revda"
license=('GPL2')
provides=('revda')
conflicts=('revda')
depends=(
	'webkit2gtk-4.1'
	'xdotool'
)

makedepends=(
	'git'
	'dioxus-cli'
	'rust'
	'just'
)

options=('!debug' '!lto')

source=(
    "Revda::git+https://github.com/THMonster/Revda.git#branch=dev"
)

pkgver() {
    cd Revda
    git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

sha256sums=(
    'SKIP'
)

build() {
    cd Revda
	# dx build -r
	just build-revda
}

package() {
	_deps+=("dmlive")
	depends+=("${_deps[@]}")

    cd Revda
	just install-revda -d "$pkgdir/usr"
	# install -vDm 755 "target/dx/revda/release/linux/app/revda" -t "$pkgdir/usr/bin/"
	# install -vDm 644 target/dx/revda/release/linux/app/assets/* -t "$pkgdir/usr/lib/revda/assets/"
	# install -vDm 644 "misc/icon/revda.svg" -t "$pkgdir/usr/share/icons/hicolor/scalable/apps"
	# install -vDm 644 "misc/revda.desktop" -t "$pkgdir/usr/share/applications"
	# install -vDm 644 "misc/dmlive-mime.desktop" -t "$pkgdir/usr/share/applications"
}
